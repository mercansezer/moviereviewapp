# Database Configuration
DATABASE=mongodb://127.0.0.1:27017/review_app

# Auth Configuration
JWT_SECRET=your_jwt_secret_key_here

# MailTrap Configuration (Email Testing)
MAIL_TRAP_USER=your_mailtrap_user_id
